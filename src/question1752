class Solution {
    public boolean check(int[] nums) {
        int count=0;
        int n = nums.length;

        for(int i=0; i<n; i++){
            //compare the current with next element(circular, as we compare the last element as well)
            if(nums[i]>nums[(i+1)%n]) {
                count ++; // counting the decreasing slopes
            }
        }
        return count <= 1;
    }
}